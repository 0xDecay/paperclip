# Paperclip server — /home/paperclip/.paperclip/instances/default/.env
# All values sourced from 1Password via `op-exec` at systemd start.
PAPERCLIP_AGENT_JWT_SECRET=
BETTER_AUTH_SECRET=

# Apollo (used by Spike for outreach research)
APOLLO_API_KEY=

# Hermes gateway — /opt/hermes/data/.env
# Discord bot credentials live here.
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=

# Agent-level bindings (declared in each agent's adapterConfig.env as
# {type: "secret_ref", secretId: "…"} — Paperclip resolves at runtime).
# These are NOT in a plaintext .env; they are Paperclip secrets.
POSTIZ_URL=
POSTIZ_API_KEY=
DISCORD_TF_CONTENT_WEBHOOK=
ANTHROPIC_API_KEY=
MINIMAX_API_KEY=
DEEPSEEK_API_KEY=

# 1Password service account (stored on VPS, not in Paperclip)
# Path by convention: /root/.secrets/op_sa_token (chmod 600)
OP_SERVICE_ACCOUNT_TOKEN=
